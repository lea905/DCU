generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Media {
  id                 String   @id
  title              String
  releaseDate        String
  duration           Int
  universe           String
  canon              Boolean
  type               String
  releaseOrder       Int
  chronologicalOrder Int
  posterUrl          String?
  summary            String?  @db.Text
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
